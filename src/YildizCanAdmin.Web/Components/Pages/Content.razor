@page "/content"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject YildizCanApiClient Api
@inject BuiltinCatalog Catalog

<PageTitle>İçerik</PageTitle>

<h1>Soru Havuzu</h1>
<p class="text-muted">
    Bir konu seç: uygulamadaki <strong>yerleşik sorular</strong> ve senin <strong>özel soruların</strong> birlikte listelenir.
    Değişiklikler ~5 dakika içinde tüm uygulamalara iner.
</p>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
@if (info is not null)
{
    <div class="alert alert-success">@info</div>
}

<div class="mb-4" style="max-width:320px">
    <label class="form-label">Konu</label>
    <select class="form-select" @bind="selectedTopic">
        @foreach (var t in Topics)
        {
            <option value="@t.Key">@t.Value</option>
        }
    </select>
</div>

<h2>Yerleşik Sorular</h2>
<p class="text-muted">Uygulamayla gelen sorular. Düzenlersen/gizlersen tüm kullanıcılarda değişir; "Sıfırla" özgün haline döndürür.</p>

@if (loading)
{
    <p><em>Yükleniyor…</em></p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:36px">#</th>
                <th>Soru (TR)</th>
                <th style="width:52px">EN</th>
                <th style="width:110px">Durum</th>
                <th style="width:300px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Catalog.ForTopic(selectedTopic))
            {
                var key = $"{selectedTopic}:{b.Idx}";
                var o = OverrideFor(key);
                var hidden = o?.Hidden == true;
                var edited = o is not null && !hidden;
                <tr>
                    <td>@(b.Idx + 1)</td>
                    <td class="@(hidden ? "text-decoration-line-through text-muted" : "")">@(o?.Tr ?? b.Tr)</td>
                    <td>@(string.IsNullOrWhiteSpace(o?.En ?? b.En) ? "—" : "✓")</td>
                    <td>
                        @if (hidden)
                        {
                            <span class="badge bg-dark">Gizli</span>
                        }
                        else if (edited)
                        {
                            <span class="badge bg-warning text-dark">Düzenlendi</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark border">Özgün</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartBuiltinEdit(key, b, o)" disabled="@busy">Düzenle</button>
                        @if (hidden)
                        {
                            <button class="btn btn-sm btn-outline-success ms-1" @onclick="() => UnhideBuiltinAsync(key, o)" disabled="@busy">Göster</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-dark ms-1" @onclick="() => HideBuiltinAsync(key, o)" disabled="@busy">Gizle</button>
                        }
                        @if (o is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => RestoreBuiltinAsync(key)" disabled="@busy">Sıfırla</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (editingBuiltinKey is not null)
{
    <div class="card mb-4 border-warning">
        <div class="card-body">
            <h5 class="card-title">Yerleşik Soruyu Düzenle <span class="text-muted fs-6">(@editingBuiltinKey)</span></h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Soru (Türkçe) *</label>
                    <textarea class="form-control" rows="2" @bind="bTr"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Soru (İngilizce)</label>
                    <textarea class="form-control" rows="2" @bind="bEn"></textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Görsel arama terimi (İngilizce)</label>
                    <input class="form-control" @bind="bQuery" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-warning" @onclick="SaveBuiltinEditAsync" disabled="@busy">Kaydet</button>
                <button class="btn btn-outline-secondary ms-2" @onclick="() => editingBuiltinKey = null" disabled="@busy">Vazgeç</button>
            </div>
        </div>
    </div>
}

<h2 class="mt-4">AI ile Öner <span class="badge bg-info text-dark fs-6">Gemini</span></h2>
<p class="text-muted">Seçili konu için soru önerileri üretir. Öneriler doğrudan yayınlanmaz — beğendiklerin <strong>taslak</strong> olarak havuza eklenir, yayın kararı sende.</p>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Seviye</label>
                <select class="form-select" @bind="gLevel">
                    <option value="word">Kelime (kısa)</option>
                    <option value="sentence">Cümle (orta)</option>
                    <option value="tell">Anlatma (uzun)</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Yaş (min)</label>
                <input type="number" class="form-control" @bind="gAgeMin" min="3" max="12" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Yaş (max)</label>
                <input type="number" class="form-control" @bind="gAgeMax" min="3" max="14" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Adet</label>
                <input type="number" class="form-control" @bind="gCount" min="1" max="8" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-info" @onclick="GenerateAsync" disabled="@(busy || generating)">
                    @(generating ? "Üretiliyor…" : $"{TopicLabel(selectedTopic)} için öner")
                </button>
            </div>
        </div>
    </div>
</div>

@if (suggestions.Count > 0)
{
    <div class="row g-3 mb-4">
        @foreach (var s in suggestions)
        {
            var added = addedSuggestions.Contains(s);
            <div class="col-md-6">
                <div class="card @(added ? "border-success" : "")">
                    <div class="card-body">
                        <p class="mb-1"><strong>@s.Tr</strong></p>
                        <p class="mb-1 text-muted">@s.En</p>
                        <p class="mb-1"><small>Hedef: @s.GoalTr</small></p>
                        <p class="mb-2"><small class="text-muted">Görsel: @s.Query</small></p>
                        @if (added)
                        {
                            <span class="badge bg-success">Taslağa eklendi</span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-primary" @onclick="() => AddSuggestionAsync(s)" disabled="@busy">Taslağa Ekle</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<h2 class="mt-4">Özel Sorular</h2>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@(editingId is null ? "Yeni Özel Soru" : "Özel Soruyu Düzenle")</h5>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Konu</label>
                <select class="form-select" @bind="fTopic">
                    @foreach (var t in Topics)
                    {
                        <option value="@t.Key">@t.Value</option>
                    }
                </select>
            </div>
            <div class="col-md-8">
                <label class="form-label">Görsel arama terimi (İngilizce, Pexels)</label>
                <input class="form-control" @bind="fQuery" placeholder="örn. happy child eating breakfast" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Soru (Türkçe) *</label>
                <textarea class="form-control" rows="2" @bind="fTr" placeholder="örn. Kahvaltıda en çok ne yersin?"></textarea>
            </div>
            <div class="col-md-6">
                <label class="form-label">Soru (İngilizce) — boşsa EN'de görünmez</label>
                <textarea class="form-control" rows="2" @bind="fEn"></textarea>
            </div>
            <div class="col-md-6">
                <label class="form-label">Hedef (Türkçe, opsiyonel)</label>
                <input class="form-control" @bind="fGoalTr" placeholder="örn. Yiyecek adı söyleyebilme" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Hedef (İngilizce, opsiyonel)</label>
                <input class="form-control" @bind="fGoalEn" />
            </div>
        </div>
        <div class="mt-3">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@busy">
                @(editingId is null ? "Taslak Olarak Kaydet" : "Güncelle")
            </button>
            @if (editingId is not null)
            {
                <button class="btn btn-outline-secondary ms-2" @onclick="ClearForm" disabled="@busy">Vazgeç</button>
            }
        </div>
    </div>
</div>

@{ var visibleCustoms = questions.Where(q => q.Topic == selectedTopic).ToList(); }
@if (!loading && visibleCustoms.Count == 0)
{
    <p>Bu konuda özel soru yok.</p>
}
else if (!loading)
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Soru (TR)</th>
                <th style="width:52px">EN</th>
                <th style="width:110px">Durum</th>
                <th style="width:260px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var q in visibleCustoms)
            {
                <tr>
                    <td>@q.Tr</td>
                    <td>@(string.IsNullOrWhiteSpace(q.En) ? "—" : "✓")</td>
                    <td>
                        @if (q.Published)
                        {
                            <span class="badge bg-success">Yayında</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Taslak</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => TogglePublishAsync(q)" disabled="@busy">
                            @(q.Published ? "Geri Çek" : "Yayınla")
                        </button>
                        <button class="btn btn-sm btn-outline-secondary ms-1" @onclick="() => EditRow(q)" disabled="@busy">Düzenle</button>
                        @if (armedDeleteId == q.Id)
                        {
                            <button class="btn btn-sm btn-danger ms-1" @onclick="() => DeleteAsync(q)" disabled="@busy">Emin misin?</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => armedDeleteId = q.Id" disabled="@busy">Sil</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private static readonly Dictionary<string, string> Topics = new()
    {
        ["greetings"] = "Selamlaşma",
        ["introduce"] = "Kendini Tanıtma",
        ["emotions"] = "Duygular",
        ["daily"] = "Günlük Yaşam",
        ["school"] = "Okul",
        ["food"] = "Yemek",
        ["hobbies"] = "Hobiler",
        ["places"] = "Yerler",
        ["problem"] = "Problem Çözme",
        ["dreams"] = "Hayaller",
    };

    private static string TopicLabel(string key) => Topics.TryGetValue(key, out var v) ? v : key;

    private bool loading = true;
    private bool busy;
    private string? error;
    private string? info;
    private string selectedTopic = "greetings";
    private List<ContentQuestion> questions = [];
    private Dictionary<string, ContentOverride> overrides = new();

    private string? editingId;
    private string? armedDeleteId;
    private string fTopic = "greetings";
    private string fTr = "";
    private string fEn = "";
    private string fGoalTr = "";
    private string fGoalEn = "";
    private string fQuery = "";

    private string? editingBuiltinKey;
    private string bTr = "";
    private string bEn = "";
    private string bQuery = "";

    private bool generating;
    private string gLevel = "sentence";
    private int gAgeMin = 4;
    private int gAgeMax = 8;
    private int gCount = 5;
    private List<GeneratedQuestion> suggestions = [];
    private readonly HashSet<GeneratedQuestion> addedSuggestions = [];

    private ContentOverride? OverrideFor(string key)
        => overrides.TryGetValue(key, out var o) ? o : null;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        loading = true;
        error = null;
        try
        {
            var r = await Api.GetContentAsync();
            questions = r.Questions;
            overrides = r.Overrides ?? new();
        }
        catch (Exception ex)
        {
            error = "Liste alınamadı: " + ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private void StartBuiltinEdit(string key, BuiltinQuestion b, ContentOverride? o)
    {
        editingBuiltinKey = key;
        bTr = o?.Tr ?? b.Tr;
        bEn = o?.En ?? b.En;
        bQuery = o?.Query ?? "";
        info = null;
        error = null;
    }

    private async Task SaveBuiltinEditAsync()
    {
        if (editingBuiltinKey is null) return;
        if (string.IsNullOrWhiteSpace(bTr)) { error = "Türkçe metin zorunlu."; return; }
        await RunAsync(async () =>
        {
            var ok = await Api.OverrideBuiltinAsync(editingBuiltinKey, bTr.Trim(), bEn.Trim(), bQuery.Trim(), hidden: false);
            if (!ok) { error = "Kaydetme başarısız — API hatası."; return; }
            info = "Yerleşik soru düzenlendi — ~5 dk içinde uygulamalara iner.";
            editingBuiltinKey = null;
            await ReloadAsync();
        });
    }

    private async Task HideBuiltinAsync(string key, ContentOverride? o)
        => await RunAsync(async () =>
        {
            var ok = await Api.OverrideBuiltinAsync(key, o?.Tr, o?.En, o?.Query, hidden: true);
            if (!ok) { error = "Gizleme başarısız — API hatası."; return; }
            info = "Soru gizlendi — uygulamalarda sorulmayacak.";
            await ReloadAsync();
        });

    private async Task UnhideBuiltinAsync(string key, ContentOverride? o)
        => await RunAsync(async () =>
        {
            var hasEdit = !string.IsNullOrWhiteSpace(o?.Tr) || !string.IsNullOrWhiteSpace(o?.En) || !string.IsNullOrWhiteSpace(o?.Query);
            var ok = hasEdit
                ? await Api.OverrideBuiltinAsync(key, o?.Tr, o?.En, o?.Query, hidden: false)
                : await Api.RestoreBuiltinAsync(key);
            if (!ok) { error = "İşlem başarısız — API hatası."; return; }
            info = "Soru tekrar gösteriliyor.";
            await ReloadAsync();
        });

    private async Task RestoreBuiltinAsync(string key)
        => await RunAsync(async () =>
        {
            var ok = await Api.RestoreBuiltinAsync(key);
            if (!ok) { error = "Sıfırlama başarısız — API hatası."; return; }
            info = "Soru özgün haline döndü.";
            if (editingBuiltinKey == key) editingBuiltinKey = null;
            await ReloadAsync();
        });

    private async Task GenerateAsync()
    {
        generating = true;
        error = null;
        info = null;
        try
        {
            if (gAgeMax < gAgeMin) gAgeMax = gAgeMin;
            suggestions = await Api.GenerateQuestionsAsync(selectedTopic, gLevel, gAgeMin, gAgeMax, gCount);
            addedSuggestions.Clear();
            if (suggestions.Count == 0) error = "Öneri üretilemedi — tekrar dene.";
        }
        catch (Exception ex)
        {
            error = "Üretim başarısız: " + ex.Message;
        }
        finally
        {
            generating = false;
        }
    }

    private async Task AddSuggestionAsync(GeneratedQuestion s)
        => await RunAsync(async () =>
        {
            var ok = await Api.UpsertContentAsync(null, selectedTopic, s.Tr, s.En, s.GoalTr, s.GoalEn, s.Query);
            if (!ok) { error = "Eklenemedi — API hatası."; return; }
            addedSuggestions.Add(s);
            info = "Öneri taslak olarak eklendi — aşağıdaki listeden yayınlayabilirsin.";
            await ReloadAsync();
        });

    private void ClearForm()
    {
        editingId = null;
        fTopic = selectedTopic;
        fTr = fEn = fGoalTr = fGoalEn = fQuery = "";
        info = null;
    }

    private void EditRow(ContentQuestion q)
    {
        editingId = q.Id;
        fTopic = q.Topic;
        fTr = q.Tr;
        fEn = q.En;
        fGoalTr = q.GoalTr;
        fGoalEn = q.GoalEn;
        fQuery = q.Query;
        info = null;
        error = null;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(fTr)) { error = "Türkçe soru metni zorunlu."; return; }
        await RunAsync(async () =>
        {
            var ok = await Api.UpsertContentAsync(editingId, fTopic, fTr.Trim(), fEn.Trim(), fGoalTr.Trim(), fGoalEn.Trim(), fQuery.Trim());
            if (!ok) { error = "Kaydetme başarısız — API hatası."; return; }
            info = editingId is null ? "Soru taslak olarak kaydedildi." : "Soru güncellendi.";
            ClearForm();
            await ReloadAsync();
        });
    }

    private async Task TogglePublishAsync(ContentQuestion q)
        => await RunAsync(async () =>
        {
            var ok = await Api.SetContentPublishedAsync(q.Id, !q.Published);
            if (!ok) { error = "İşlem başarısız — API hatası."; return; }
            info = q.Published ? "Soru yayından çekildi." : "Soru yayınlandı — ~5 dk içinde uygulamalara iner.";
            await ReloadAsync();
        });

    private async Task DeleteAsync(ContentQuestion q)
    {
        armedDeleteId = null;
        await RunAsync(async () =>
        {
            var ok = await Api.DeleteContentAsync(q.Id);
            if (!ok) { error = "Silme başarısız — API hatası."; return; }
            info = "Soru silindi.";
            if (editingId == q.Id) ClearForm();
            await ReloadAsync();
        });
    }

    private async Task RunAsync(Func<Task> work)
    {
        busy = true;
        error = null;
        info = null;
        try
        {
            await work();
        }
        catch (Exception ex)
        {
            error = "İşlem başarısız: " + ex.Message;
        }
        finally
        {
            busy = false;
        }
    }
}
