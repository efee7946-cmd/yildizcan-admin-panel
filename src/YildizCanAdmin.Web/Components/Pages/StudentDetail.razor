@page "/students/{AccountUser}/{StudentId}"
@using System.Text.Json
@using YildizCanAdmin.Shared
@using YildizCanAdmin.Web.Services
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject YildizCanApiClient Api

<PageTitle>Öğrenci Detayı</PageTitle>

<p><a href="/students">← Öğrenci listesine dön</a></p>

@if (loading)
{
    <p><em>Yükleniyor…</em></p>
}
else if (error is not null)
{
    <div class="alert alert-danger" role="alert">Veri alınamadı: @error</div>
}
else if (detail is null)
{
    <p>Öğrenci bulunamadı.</p>
}
else
{
    var s = detail.Student;
    var sum = detail.Summary;

    <h1>@(string.IsNullOrWhiteSpace(s.FullName) ? "(isimsiz)" : s.FullName)</h1>
    <p class="text-muted">
        Hesap: <strong>@s.Username</strong>
        @if (s.BirthYear is not null)
        {
            <span> · Doğum yılı: <strong>@s.BirthYear</strong></span>
        }
    </p>
    @if (!string.IsNullOrWhiteSpace(s.SupportNotes))
    {
        <p><strong>Destek notu:</strong> @s.SupportNotes</p>
    }

    <h2>Nesne Tanıma Özeti</h2>
    <div class="row mb-3">
        <div class="col-6 col-md-3"><div class="card p-3 text-center"><div class="fs-3">@sum.Plays</div><div class="text-muted">Oyun</div></div></div>
        <div class="col-6 col-md-3"><div class="card p-3 text-center"><div class="fs-3">@(sum.Accuracy is null ? "—" : $"%{sum.Accuracy}")</div><div class="text-muted">Doğruluk</div></div></div>
        <div class="col-6 col-md-3"><div class="card p-3 text-center"><div class="fs-3">@sum.Perfect</div><div class="text-muted">Hatasız oyun</div></div></div>
        <div class="col-6 col-md-3"><div class="card p-3 text-center"><div class="fs-3">@(sum.LastPlayed?.ToLocalTime().ToString("dd.MM.yyyy") ?? "—")</div><div class="text-muted">Son oyun</div></div></div>
    </div>

    <h2>Doğruluk Gelişimi</h2>
    <p class="text-muted">Nesne tanıma seanslarında doğruluk yüzdesi (eski → yeni).</p>
    @if (chartPoints.Count < 2)
    {
        <p class="text-muted"><em>Grafik için en az iki seans gerekli.</em></p>
    }
    else
    {
        <div class="acc-chart mb-4">
            <style>
                .acc-chart svg { max-width: 680px; width: 100%; height: auto; display: block; }
                .acc-chart text { font-family: system-ui, -apple-system, "Segoe UI", sans-serif; }
                .acc-chart .tick { font-variant-numeric: tabular-nums; }
                .acc-chart .pt .tip { opacity: 0; pointer-events: none; transition: opacity .1s; }
                .acc-chart .pt:hover .tip { opacity: 1; }
                .acc-chart .pt:hover .dot { r: 5px; }
            </style>
            <svg viewBox="0 0 640 240" role="img" aria-label="Doğruluk gelişimi grafiği">
                @foreach (var g in new[] { 100, 75, 50, 25 })
                {
                    <line x1="44" y1="@((int)Y(g))" x2="624" y2="@((int)Y(g))" stroke="#e9ecef" stroke-width="1" />
                }
                <line x1="44" y1="@((int)Y(0))" x2="624" y2="@((int)Y(0))" stroke="#ced4da" stroke-width="1" />
                @foreach (var g in new[] { 0, 25, 50, 75, 100 })
                {
                    <g><text class="tick" x="38" y="@((int)Y(g) + 4)" text-anchor="end" font-size="11" fill="#6c757d">%@g</text></g>
                }
                @foreach (var t in xTicks)
                {
                    <g><text class="tick" x="@t.X" y="232" text-anchor="middle" font-size="11" fill="#6c757d">@t.Label</text></g>
                }
                <polyline points="@string.Join(" ", chartPoints.Select(p => $"{p.X},{p.Y}"))"
                          fill="none" stroke="#2a78d6" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
                @foreach (var p in chartPoints)
                {
                    <g class="pt">
                        <circle cx="@p.X" cy="@p.Y" r="12" fill="transparent" />
                        <circle class="dot" cx="@p.X" cy="@p.Y" r="4" fill="#2a78d6" stroke="#ffffff" stroke-width="2" />
                        <g class="tip">
                            <rect x="@(p.TipX - 95)" y="@p.TipY" width="190" height="22" rx="4" fill="#212529" opacity="0.92" />
                            <text x="@p.TipX" y="@(p.TipY + 15)" text-anchor="middle" font-size="11" fill="#ffffff">@p.Tip</text>
                        </g>
                    </g>
                }
                <text x="@chartPoints[^1].X" y="@(chartPoints[^1].Y - 10)" text-anchor="middle" font-size="12" font-weight="600" fill="#212529">%@chartPoints[^1].Acc</text>
            </svg>
        </div>
    }

    <h2>Nesne Tanıma Seansları</h2>
    @if (sessions is null || sessions.ObjResults.Count == 0)
    {
        <p>Henüz nesne tanıma seansı yok.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr><th>Tarih</th><th>Doğru</th><th>Hata</th><th>Doğruluk</th></tr>
            </thead>
            <tbody>
                @foreach (var r in sessions.ObjResults)
                {
                    <tr>
                        <td>@(r.Date?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                        <td>@(r.Items?.ToString() ?? "—")</td>
                        <td>@(r.Errors?.ToString() ?? "—")</td>
                        <td>@(r.Accuracy is null ? "—" : $"%{r.Accuracy}")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h2>Konuşma Pratiği Seansları</h2>
    @if (sessions is null || sessions.SpeechHistory.Count == 0)
    {
        <p>Henüz konuşma pratiği seansı yok.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr><th>Tarih</th><th>Süre (dk)</th><th>Konuşma turu</th><th>Hikâye</th></tr>
            </thead>
            <tbody>
                @foreach (var h in sessions.SpeechHistory)
                {
                    <tr>
                        <td>@P(h, "session_date")</td>
                        <td>@P(h, "duration_min")</td>
                        <td>@P(h, "total_turns")</td>
                        <td>@P(h, "story_name")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public string AccountUser { get; set; } = "";
    [Parameter] public string StudentId { get; set; } = "";

    private bool loading = true;
    private string? error;
    private StudentDetailResponse? detail;
    private SessionsResponse? sessions;

    private sealed record ChartPoint(int X, int Y, int Acc, string Tip, int TipX, int TipY);
    private List<ChartPoint> chartPoints = [];
    private List<(int X, string Label)> xTicks = [];

    private const int PlotL = 44, PlotR = 624, PlotT = 16, PlotB = 212;

    private static int Y(double accuracy) => (int)Math.Round(PlotT + (100 - accuracy) / 100.0 * (PlotB - PlotT));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            detail = await Api.GetStudentAsync(AccountUser, StudentId);
            sessions = await Api.GetSessionsAsync(AccountUser, StudentId);
            BuildChart();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private void BuildChart()
    {
        var pts = (sessions?.ObjResults ?? [])
            .Where(r => r.Accuracy is not null && r.Date is not null)
            .OrderBy(r => r.Date)
            .ToList();
        var n = pts.Count;
        chartPoints = pts.Select((r, i) =>
        {
            var x = n == 1 ? (PlotL + PlotR) / 2 : PlotL + (int)Math.Round(i * (double)(PlotR - PlotL) / (n - 1));
            var y = Y(r.Accuracy!.Value);
            var d = r.Date!.Value.ToLocalTime();
            var tipY = y - 38 < PlotT ? y + 12 : y - 38;
            return new ChartPoint(x, y, r.Accuracy.Value,
                $"{d:dd.MM.yyyy} · %{r.Accuracy} ({r.Items ?? 0} doğru, {r.Errors ?? 0} hata)",
                Math.Clamp(x, PlotL + 95, PlotR - 95), tipY);
        }).ToList();

        var tickIdx = n <= 3
            ? Enumerable.Range(0, n)
            : new[] { 0, n / 2, n - 1 };
        xTicks = tickIdx.Distinct()
            .Select(i => (chartPoints[i].X, pts[i].Date!.Value.ToLocalTime().ToString("dd.MM.yy")))
            .ToList();
    }

    private static string P(JsonElement e, string name)
        => e.ValueKind == JsonValueKind.Object && e.TryGetProperty(name, out var v) && v.ValueKind != JsonValueKind.Null
            ? v.ToString()
            : "—";
}
